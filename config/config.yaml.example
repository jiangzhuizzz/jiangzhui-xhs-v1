# 小红书运营项目配置模板
# 复制此文件为 config.yaml 并填写实际配置

# ==================== 飞书配置 ====================
feishu:
  app_id: "your_app_id_here"           # 飞书应用 ID
  app_secret: "your_app_secret_here"   # 飞书应用密钥
  app_token: "your_app_token_here"     # 飞书多维表格 App Token
  table_id_topics: "your_table_id"     # 选题库表格 ID
  table_id_notes: "your_table_id"      # 笔记库表格 ID

# ==================== 小红书配置 ====================
xiaohongshu:
  openclaw_url: "http://127.0.0.1:18789"  # OpenClaw Gateway 地址
  cdp_port: 18789                          # Chrome DevTools Protocol 端口

# ==================== 图片配置 ====================
image:
  theme: "sketch"        # 主题: default/playful-geometric/neo-brutalism/botanical/professional/retro/terminal/sketch
  mode: "auto-split"     # 分页模式: separator/auto-fit/auto-split/dynamic

# ==================== 工作流环节 ====================
# 完整流程：选题 → 初稿 → 违禁词检测 → 配图 → 人工审核 → 待发布 → 已发布

workflow:
  stages:
    - 选题       # 选题库中选定的选题
    - 初稿       # AI生成的文案初稿
    - 检测       # 违禁词检测
    - 配图       # 图片渲染完成
    - 审核       # 人工审核确认
    - 待发布     # 已保存到小红书草稿箱
    - 已发布     # 已发布到小红书

# ==================== 违禁词配置 ====================
check:
  max_retries: 3

# ==================== 运营提示词（可直接调用） ====================
# 使用方式：读取此配置的 prompts 字段，注入到 AI 生成

prompts:
  # 账号状态说明
  account_status: |
    当前账号状态：新账号（冷启动），粉丝 0-500
    内容策略：情感类、生活类为主，少发营销内容
    安全提示：禁止引导私信、禁止承诺 100% 下款

  # 内容类型映射
  content_types:
    情感共鸣: "情感故事、心情分享，适合晚上发"
    武汉生活: "过早、美食、周末玩法，适合中午/傍晚"
    贷款干货: "公积金、信贷知识，需案例包装"
    工具类: "测评、教程类"

  # 小红书文案生成核心提示词（详细指南）
  # 包含：标题技巧、正文模板、风格要点、话题策略、合规要点等
  # 使用时读取此字段，注入到 AI 生成提示词中
  xiaohongshu_writing_guide: |
    # 小红书文案生成指南
    
    ## 一、标题撰写技巧
    ### 1. 标题公式（选其一）
    - 【数字型】：武汉过早plog｜这一碗热干面才8块钱
    - 【疑问型】：公积金贷款真的比商贷划算吗？
    - 【对比型】：信用贷 vs 抵押贷，哪个更适合你？
    - 【情感型】：在武汉3年，终于找到了家的感觉
    - 【干货型】：公积金贷款避坑指南｜新手必看
    
    ### 2. 标题要素
    - ✅ 包含关键词（地域/产品/场景）
    - ✅ 制造悬念或好奇
    - ✅ 数字具体化（8块钱 > 便宜）
    - ✅ 使用emoji增加视觉吸引力
    - ❌ 避免标题党（不要过度夸张）
    - ❌ 避免违禁词（互粉、私信、100%等）
    
    ## 二、正文结构模板
    ### 模板 1：生活分享型
    【开头】一句话引入场景/情感
    【正文】为什么推荐/分享这个？具体细节（价格/位置/体验）个人感受/故事
    【结尾】互动引导（你有类似经历吗？）
    【话题】#地域标签 #内容标签 #情感标签
    
    ### 模板 2：干货攻略型
    【开头】痛点/问题引入
    【正文】核心知识点（3-5条）每条配具体案例/数据 避坑提示
    【结尾】总结 + 互动
    【话题】#干货 #攻略 #行业标签
    
    ## 三、小红书风格要点
    - ✅ 口语化、接地气（"真的绝了" "太香了"）
    - ✅ 适当使用emoji（但不要过多）
    - ✅ 分段清晰（每段2-3行）
    - ✅ 使用列表/序号（提高可读性）
    - ❌ 避免官方腔调
    - ❌ 避免长段落（超过5行）
    
    ## 四、合规要点（重要！）
    ### 高危违禁词（必须避免）
    - 引导私信：互粉、私信、加微信、找我
    - 承诺类：包下款、100%、必过、秒批
    - 违规金融：套现、代办、包装资料
    
    ### 替换方案
    - "私信我" → "评论区交流"
    - "包下款" → "帮助申请"
    - "100%" → "大概率"
    - "贷款中介" → "金融咨询师"
    - "点赞收藏" → "喜欢的话可以支持一下"

  # 生成模板
  template: |
    # {{标题}}
    
    {{正文}}
    
    #{{话题1}} #{{话题2}} #{{话题3}}

  # 违禁词提醒
  forbidden_words:
    - "互粉"
    - "找我"
    - "私信"
    - "贷款中介"
    - "包下款"
    - "100%"

# ==================== 图片输出目录 ====================
output:
  picture_dir: "./picture"

# ==================== Telegram 通知配置 ====================
telegram:
  enabled: true                    # 是否启用 Telegram 通知
  chat_id: "your_telegram_id"      # 你的 Telegram ID（可通过 @userinfobot 获取）
  notify_on:
    - sync_success    # Git 同步成功
    - sync_failure    # Git 同步失败
    - publish_success # 发布成功
    - publish_failure # 发布失败
    - render_complete # 图片渲染完成
